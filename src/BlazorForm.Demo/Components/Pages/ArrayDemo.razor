@page "/array"
@rendermode InteractiveServer
@implements IDisposable

<PageTitle>Array / repeater</PageTitle>

<div class="demo-intro">
    <h1>Array / repeater</h1>
    <p>Array fields render a repeating editor with add, remove and reorder. Each item is a nested object validated like any other field. The total below updates live from form state.</p>
</div>

<div class="demo-card">
    <BlazorFormView State="_state" OnValidSubmit="HandleSubmit" SubmitText="Save invoice" />
    <p style="font-weight:600; font-size:1.1rem; margin-top:1rem; text-align:right">
        Total: @Total.ToString("C")
    </p>
</div>

@if (_submitted)
{
    <div class="demo-result"><strong>Saved ✓</strong> <pre>@_json</pre></div>
}

<details class="demo-source">
    <summary>View source</summary>
    <pre><code>@Source</code></pre>
</details>

@code {
    private const string Source =
"""
@page "/array"
@rendermode InteractiveServer
@implements IDisposable

<BlazorFormView State="_state" OnValidSubmit="HandleSubmit" SubmitText="Save invoice" />
<p>Total: @Total.ToString("C")</p>

@code {
    private readonly Invoice _model = new();
    private BlazorFormState _state = default!;

    protected override void OnInitialized()
    {
        var schema = BlazorFormBuilder.For<Invoice>()
            .Title("New invoice")
            .Field(x => x.Customer, f => f.Required())
            .Field(x => x.Lines, f => f.Items(min: 1, message: "Add at least one line.").Attr("itemNoun", "line"))
            .Build();

        _state = new BlazorFormState(schema, new BlazorFormModelDataAccessor(_model));
        _state.StateChanged += OnStateChanged;
    }

    private decimal Total => _model.Lines.Sum(l => l.Quantity * l.UnitPrice);

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    private void HandleSubmit(BlazorFormState state)
    {
        var json = System.Text.Json.JsonSerializer.Serialize(_model,
            new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
    }

    public void Dispose() => _state.StateChanged -= OnStateChanged;
}
""";

    private readonly Invoice _model = new();
    private BlazorFormState _state = default!;
    private bool _submitted;
    private string _json = "";

    protected override void OnInitialized()
    {
        var schema = BlazorFormBuilder.For<Invoice>()
            .Title("New invoice")
            .Field(x => x.Customer, f => f.Required())
            .Field(x => x.Lines, f => f.Items(min: 1, message: "Add at least one line.").Attr("itemNoun", "line"))
            .Build();

        _state = new BlazorFormState(schema, new BlazorFormModelDataAccessor(_model));
        _state.StateChanged += OnStateChanged;
    }

    private decimal Total => _model.Lines.Sum(l => l.Quantity * l.UnitPrice);

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    private void HandleSubmit(BlazorFormState state)
    {
        _submitted = true;
        _json = System.Text.Json.JsonSerializer.Serialize(_model,
            new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
    }

    public void Dispose() => _state.StateChanged -= OnStateChanged;
}
