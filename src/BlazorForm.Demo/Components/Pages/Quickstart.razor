@page "/quickstart"
@rendermode InteractiveServer

<PageTitle>From a C# type</PageTitle>

<div class="demo-intro">
    <h1>From a C# type</h1>
    <p>One line generates a complete form from any POCO. Labels, field types, options and validation come from the type and its DataAnnotations.</p>
</div>

<div class="demo-card">
    <BlazorFormView Definition="_schema" Model="_model" OnValidSubmit="HandleSubmit" SubmitText="Create account" />
</div>

@if (_submitted)
{
    <div class="demo-result">
        <strong>Submitted ✓</strong>
        <pre>@_json</pre>
    </div>
}

<details class="demo-source">
    <summary>View source</summary>
    <pre><code>@Source</code></pre>
</details>

@code {
    private const string Source =
"""
@page "/quickstart"
@rendermode InteractiveServer

<BlazorFormView Definition="_schema" Model="_model" OnValidSubmit="HandleSubmit" SubmitText="Create account" />

@code {
    private readonly AccountSignup _model = new();
    private BlazorFormDefinition _schema = default!;

    protected override void OnInitialized()
    {
        // Zero-config: generate the whole form from the type.
        _schema = BlazorFormSchemaGenerator.Generate<AccountSignup>();
    }

    private void HandleSubmit(BlazorFormState state)
    {
        var json = System.Text.Json.JsonSerializer.Serialize(_model,
            new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
    }
}
""";

    private readonly AccountSignup _model = new();
    private BlazorFormDefinition _schema = default!;
    private bool _submitted;
    private string _json = "";

    protected override void OnInitialized()
    {
        // Zero-config: generate the whole form from the type.
        _schema = BlazorFormSchemaGenerator.Generate<AccountSignup>();
    }

    private void HandleSubmit(BlazorFormState state)
    {
        _submitted = true;
        _json = System.Text.Json.JsonSerializer.Serialize(_model,
            new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
    }
}
