@inherits LayoutComponentBase

<div class="app-shell">
    <aside class="app-nav">
        <div class="app-brand">Form<span>Forge</span></div>
        <nav>
            <NavLink href="/" Match="NavLinkMatch.All">Overview</NavLink>
            <NavLink href="/quickstart">From a C# type</NavLink>
            <NavLink href="/builder">Fluent builder + conditions</NavLink>
            <NavLink href="/array">Array / repeater</NavLink>
            <NavLink href="/wizard">Multi-step wizard</NavLink>
            <NavLink href="/json-schema">JSON Schema</NavLink>
            <NavLink href="/fluent-validation">FluentValidation</NavLink>
            <NavLink href="/custom-renderer">Custom renderer</NavLink>
        </nav>
    </aside>
    <main class="app-main">
        @Body
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

<style>
    .app-shell { display: flex; min-height: 100vh; font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif; }
    .app-nav { width: 240px; flex: none; background: #0f172a; color: #cbd5e1; padding: 1.25rem 1rem; }
    .app-brand { font-size: 1.3rem; font-weight: 700; color: #fff; margin-bottom: 1.5rem; }
    .app-brand span { color: #818cf8; }
    .app-nav nav { display: flex; flex-direction: column; gap: .15rem; }
    .app-nav a { color: #cbd5e1; text-decoration: none; padding: .5rem .65rem; border-radius: 8px; font-size: .9rem; }
    .app-nav a:hover { background: #1e293b; color: #fff; }
    .app-nav a.active { background: #4f46e5; color: #fff; }
    .app-main { flex: 1; padding: 2.5rem; background: #f8fafc; overflow-x: hidden; }
    .demo-intro { max-width: 720px; margin-bottom: 1.75rem; }
    .demo-intro h1 { margin: 0 0 .35rem; font-size: 1.7rem; }
    .demo-intro p { color: #475569; margin: 0; }
    .demo-card { background: #fff; border: 1px solid #e2e8f0; border-radius: 14px; padding: 1.75rem; max-width: 760px; box-shadow: 0 1px 3px rgba(0,0,0,.04); }
    .demo-result { max-width: 760px; margin-top: 1.25rem; background: #ecfdf5; border: 1px solid #a7f3d0; border-radius: 10px; padding: 1rem 1.25rem; }
    .demo-result pre { margin: .5rem 0 0; white-space: pre-wrap; word-break: break-word; font-size: .82rem; }
    .demo-split { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; max-width: 1100px; align-items: start; }
    .demo-split textarea { width: 100%; min-height: 460px; font-family: ui-monospace, "Cascadia Code", monospace; font-size: .8rem; border: 1px solid #cbd5e1; border-radius: 10px; padding: 1rem; box-sizing: border-box; }
    @@media (max-width: 900px) { .app-shell { flex-direction: column; } .app-nav { width: auto; } .demo-split { grid-template-columns: 1fr; } }
</style>
