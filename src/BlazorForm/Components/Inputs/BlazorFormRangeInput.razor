@namespace BlazorForm
@inherits BlazorFormInputBase

<div class="ff-range">
    <input id="@Context.ElementId"
           class="ff-range__slider"
           type="range"
           value="@Context.StringValue"
           disabled="@Disabled"
           min="@(Field.Min ?? 0)"
           max="@(Field.Max ?? 100)"
           step="@Step"
           @oninput="OnChange" />
    <output class="ff-range__value">@Context.StringValue</output>
</div>

@code {
    private string Step => Field.NumericStep?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "1";
}
